{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "composite": false,
    "rootDir": "../../../../../",
    "allowImportingTsExtensions": true,
    "paths": {
      "@tuvren/core-types": [
        "../../../../shared/contracts/core-types/implementations/typescript/src/index.ts"
      ],
      "@tuvren/driver-react": ["../drivers/react/src/index.ts"],
      "@tuvren/kernel-protocol": [
        "../../../../kernel/contracts/protocol/implementations/typescript/src/index.ts"
      ],
      "@tuvren/kernel-runtime": [
        "../../../../kernel/implementations/typescript/runtime-kernel/src/index.ts"
      ],
      "@tuvren/runtime": ["./src/index.ts"],
      "@tuvren/runtime-api": [
        "../../../contracts/runtime-api/implementations/typescript/src/index.ts"
      ],
      "@tuvren/runtime-core": ["../runtime-core/src/index.ts"]
    },
    "types": ["bun"]
  },
  "include": [
    "src/**/*.ts",
    "smoke/**/*.ts",
    "../../../../shared/contracts/core-types/implementations/typescript/src/**/*.ts",
    "../../../../kernel/contracts/protocol/implementations/typescript/src/**/*.ts",
    "../../../../kernel/implementations/typescript/runtime-kernel/src/**/*.ts",
    "../../../contracts/runtime-api/implementations/typescript/src/**/*.ts",
    "../drivers/react/src/**/*.ts",
    "../runtime-core/src/**/*.ts"
  ]
}
