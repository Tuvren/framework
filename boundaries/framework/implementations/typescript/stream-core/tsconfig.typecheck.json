{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "composite": false,
    "rootDir": "../../../../../",
    "allowImportingTsExtensions": true,
    "paths": {
      "@tuvren/core": ["../../../../../typescript/core/src/index.ts"],
      "@tuvren/core-types": [
        "../../../../../typescript/core-types/src/index.ts"
      ],
      "@tuvren/core/driver": [
        "../../../../../typescript/core/src/driver/index.ts"
      ],
      "@tuvren/core/errors": [
        "../../../../../typescript/core/src/errors/index.ts"
      ],
      "@tuvren/core/events": [
        "../../../../../typescript/core/src/events/index.ts"
      ],
      "@tuvren/core/execution": [
        "../../../../../typescript/core/src/execution/index.ts"
      ],
      "@tuvren/core/extensions": [
        "../../../../../typescript/core/src/extensions/index.ts"
      ],
      "@tuvren/core/messages": [
        "../../../../../typescript/core/src/messages/index.ts"
      ],
      "@tuvren/core/provider": [
        "../../../../../typescript/core/src/provider/index.ts"
      ],
      "@tuvren/core/tools": [
        "../../../../../typescript/core/src/tools/index.ts"
      ],
      "@tuvren/event-stream": [
        "../../../contracts/event-stream/implementations/typescript/src/index.ts"
      ],
      "@tuvren/framework-testkit": ["../testkit/src/index.ts"],
      "@tuvren/runtime-api": [
        "../../../contracts/runtime-api/implementations/typescript/src/index.ts"
      ],
      "@tuvren/runtime-api/events": [
        "../../../contracts/runtime-api/implementations/typescript/src/events.ts"
      ],
      "@tuvren/stream-core": ["./src/index.ts"]
    },
    "types": ["bun"]
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "smoke/**/*.ts",
    "../testkit/src/**/*.ts",
    "../../../contracts/event-stream/implementations/typescript/src/**/*.ts",
    "../../../contracts/runtime-api/implementations/typescript/src/**/*.ts",
    "../../../../../typescript/core-types/src/**/*.ts"
  ]
}
