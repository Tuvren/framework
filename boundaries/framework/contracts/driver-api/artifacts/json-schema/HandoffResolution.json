{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuvren.dev/schemas/framework/driver-api/HandoffResolution.json",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "handoff"
    },
    "targetAgent": {
      "$ref": "https://tuvren.dev/schemas/framework/driver-api/NonEmptyString.json"
