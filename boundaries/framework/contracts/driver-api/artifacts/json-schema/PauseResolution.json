{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuvren.dev/schemas/framework/driver-api/PauseResolution.json",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "pause"
    },
    "reason": {
      "type": "string"
    },
    "approval": {
      "$ref": "https://tuvren.dev/schemas/framework/driver-api/ApprovalRequest.json"
    }
  },
  "required": ["type", "reason", "approval"],
  "unevaluatedProperties": {
    "not": {}
  }
}
