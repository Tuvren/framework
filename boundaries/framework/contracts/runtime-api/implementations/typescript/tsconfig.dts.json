      "@tuvren/core/errors": [
        "../../../../../../typescript/core/dist/errors/index.d.ts"
      ],
      "@tuvren/core/messages": [
        "../../../../../../typescript/core/dist/messages/index.d.ts"
      ],
      "@tuvren/core/events": [
        "../../../../../../typescript/core/dist/events/index.d.ts"
      ],
      "@tuvren/core/execution": [
        "../../../../../../typescript/core/dist/execution/index.d.ts"
      ],
      "@tuvren/core/tools": [
        "../../../../../../typescript/core/dist/tools/index.d.ts"
      ],
      "@tuvren/core/driver": [
        "../../../../../../typescript/core/dist/driver/index.d.ts"
      ],
