{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "composite": false,
    "rootDir": "../../../../../",
    "allowImportingTsExtensions": true,
    "paths": {
      "@tuvren/core": ["../../../../../typescript/core/src/index.ts"],
      "@tuvren/core/errors": [
        "../../../../../typescript/core/src/errors/index.ts"
      ],
      "@tuvren/core/tools": [
        "../../../../../typescript/core/src/tools/index.ts"
      ],
      "@tuvren/sdk": ["../../../../../typescript/sdk/src/index.ts"],
      "@tuvren/mcp-client": ["./src/index.ts"],
      "@tuvren/provider-testkit": [
        "../../../../../typescript/providers/testkit/src/index.ts"
      ]
    },
    "types": ["bun", "node"]
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "smoke/**/*.ts",
    "../../../../../typescript/providers/testkit/src/**/*.ts",
    "../../../../../typescript/core/src/**/*.ts",
    "../../../../../typescript/sdk/src/**/*.ts"
  ]
}
