{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "paths": {
      "@tuvren/core": ["../../../../../typescript/core/dist/index.d.ts"],
      "@tuvren/core/errors": [
        "../../../../../typescript/core/dist/errors/index.d.ts"
      ],
      "@tuvren/core/tools": [
        "../../../../../typescript/core/dist/tools/index.d.ts"
      ],
      "@tuvren/sdk": ["../../../../../typescript/sdk/dist/index.d.ts"]
    },
    "rootDir": "./src",
    "target": "esnext",
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts"]
}
