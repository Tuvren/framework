{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuvren.dev/schemas/framework/event-stream/IterationStartEvent.json",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "iteration.start"
    },
    "iterationCount": {
      "$ref": "https://tuvren.dev/schemas/framework/event-stream/NonNegativeSafeInt.json"
    }
  },
  "required": ["type", "iterationCount"],
  "allOf": [
    {
      "$ref": "https://tuvren.dev/schemas/framework/event-stream/BaseEvent.json"
    }
  ],
  "unevaluatedProperties": {
    "not": {}
  }
}
