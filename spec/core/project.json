{
  "name": "core-spec",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "spec/core",
  "projectType": "library",
  "tags": ["boundary:shared", "layer:contract"],
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/spec/core/typespec/**/*",
        "{workspaceRoot}/spec/core/artifacts/**/*",
        "{workspaceRoot}/bun.lock"
      ],
      "outputs": ["{workspaceRoot}/spec/core/artifacts/json-schema"],
      "options": {
        "cwd": "spec/core",
        "command": "bunx --bun tsp compile ./typespec --pretty false && bunx --bun @biomejs/biome check --write ./artifacts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "inputs": ["default", "{workspaceRoot}/biome.jsonc"],
      "options": {
        "cwd": ".",
        "command": "bunx --bun @biomejs/biome check spec/core"
      }
    }
  }
}
