{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuvren.dev/schemas/framework/runtime-api/ExecutionStatus.json",
  "type": "object",
  "properties": {
    "phase": {
      "anyOf": [
        {
          "type": "string",
          "const": "running"
        },
        {
          "type": "string",
          "const": "paused"
        },
        {
          "type": "string",
          "const": "completed"
        },
        {
          "type": "string",
          "const": "failed"
        }
      ]
    },
    "iterationCount": {
      "$ref": "https://tuvren.dev/schemas/framework/runtime-api/NonNegativeSafeInt.json"
    },
    "activeAgent": {
      "$ref": "https://tuvren.dev/schemas/framework/runtime-api/NonEmptyString.json"
    },
    "approval": {
      "$ref": "https://tuvren.dev/schemas/framework/runtime-api/ApprovalRequest.json"
    },
    "manifest": {
      "$ref": "https://tuvren.dev/schemas/framework/runtime-api/ContextManifest.json"
    },
    "pauseReason": {
      "type": "string"
    }
  },
  "required": ["phase", "iterationCount"],
  "unevaluatedProperties": {
    "not": {}
  }
}
