{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuvren.dev/schemas/framework/host-session/StructuredPart.json",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "structured"
    },
    "data": {},
    "name": {
      "type": "string"
    },
    "providerMetadata": {
      "$ref": "https://tuvren.dev/schemas/framework/host-session/Metadata.json"
    }
  },
  "required": ["type", "data"],
  "unevaluatedProperties": {
    "not": {}
  },
  "description": "Mirrors `StructuredPart` in the runtime-api authority packet\n(`spec/host/typespec/main.tsp`). Must stay in sync with that declaration."
}
