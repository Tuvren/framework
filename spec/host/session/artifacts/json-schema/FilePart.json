{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuvren.dev/schemas/framework/host-session/FilePart.json",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "file"
    },
    "data": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          }
        }
      ]
    },
    "mediaType": {
      "$ref": "https://tuvren.dev/schemas/framework/host-session/NonEmptyString.json"
    },
    "filename": {
      "type": "string"
    },
    "providerMetadata": {
      "$ref": "https://tuvren.dev/schemas/framework/host-session/Metadata.json"
    }
  },
  "required": ["type", "data", "mediaType"],
  "unevaluatedProperties": {
    "not": {}
  },
  "description": "Mirrors `FilePart` in the runtime-api authority packet\n(`spec/host/typespec/main.tsp`). Must stay in sync with that declaration."
}
