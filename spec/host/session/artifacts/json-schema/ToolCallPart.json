  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "tool_call"
    },
    "callId": {
      "$ref": "https://tuvren.dev/schemas/framework/host-session/NonEmptyString.json"
    },
    "name": {
      "$ref": "https://tuvren.dev/schemas/framework/host-session/NonEmptyString.json"
    },
