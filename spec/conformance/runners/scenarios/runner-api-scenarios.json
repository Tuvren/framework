          {
            "type": "tool_call",
            "callId": "call-search",
            "name": "search",
            "input": { "query": "runner hook measurement" }
          }
        ]
      },
      {
        "finishReason": "stop",
        "parts": [{ "type": "text", "text": "runner hook turn completed" }]
      }
    ],
    "toolResult": { "ok": true, "source": "shared runner scenario" }
  },
  "runner-resume-approval": {
    "operation": "runner.resume",
