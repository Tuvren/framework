{
  "planId": "tuvren.framework.host-session.core",
  "planVersion": "0.3.0",
  "packetId": "tuvren.framework.host-session",
  "applicability": {
    "capabilities": ["framework.host-session"]
  },
  "fixtures": {
    "host-session-fixtures": "../fixtures/host-session-fixtures.json"
  },
  "checks": [
    {
      "checkId": "host-session.stale-client-result-rejected",
      "operation": "host-session.stale-client-result",
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.rejection.code",
          "equals": "capability_result_stale"
        },
        {
          "kind": "resultField",
          "field": "$.rejection.correlationId",
          "equals": "corr-stale-1"
        },
        {
          "kind": "resultField",
          "field": "$.accepted.callId",
          "equals": "call-1"
        },
        {
          "kind": "resultField",
          "field": "$.finalPhase",
          "equals": "completed"
        }
      ],
      "evidence": [
        "rejection.code",
        "rejection.correlationId",
        "accepted.callId",
        "finalPhase"
      ]
    },
    {
      "checkId": "host-session.approval-response-resumes-from-checkpoint",
      "operation": "host-session.approval-response-resume",
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.handleSwapped",
          "equals": true
        },
        {
          "kind": "resultField",
          "field": "$.resumedPhase",
          "equals": "completed"
        },
        {
          "kind": "eventSequence",
          "contains": "approval.resolved"
        },
        {
          "kind": "ordering",
          "contains": ["approval.resolved", "tool.start"]
        }
      ],
      "evidence": ["handleSwapped", "resumedPhase"]
    },
    {
      "checkId": "host-session.cancel-propagates-cooperatively",
      "operation": "host-session.cancel-cooperative",
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.toolObservedAbort",
          "equals": true
        },
        {
          "kind": "resultField",
          "field": "$.finalPhase",
          "equals": "failed"
        },
        {
          "kind": "resultField",
          "field": "$.awaitResultStatus",
          "equals": "failed"
        },
        {
          "kind": "resultField",
          "field": "$.awaitResultErrorCode",
          "equals": "execution_cancelled"
        }
      ],
      "evidence": [
        "toolObservedAbort",
        "finalPhase",
        "awaitResultStatus",
        "awaitResultErrorCode"
      ]
    },
    {
      "checkId": "host-session.cancel-while-paused-terminates-stream",
      "operation": "host-session.cancel-while-paused",
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.pausedBeforeCancel",
          "equals": true
        },
        {
          "kind": "resultField",
          "field": "$.outboundClosed",
          "equals": true
        },
        {
          "kind": "resultField",
          "field": "$.awaitResultStatus",
          "equals": "completed"
        }
      ],
      "evidence": ["pausedBeforeCancel", "outboundClosed", "awaitResultStatus"]
    },
    {
      "checkId": "host-session.frame-schema-validation",
      "operation": "host-session.validate-frame-fixtures",
      "fixture": "host-session-fixtures",
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.frameValidation.allMatch",
          "equals": true
        },
        {
          "kind": "resultField",
          "field": "$.frameValidation.count",
          "equals": 16
        }
      ],
      "evidence": ["frameValidation.allMatch", "frameValidation.count"]
    },
    {
      "checkId": "host-session.reattach-redelivers-unanswered-invocation",
      "operation": "host-session.reattach-redelivery",
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.sameCallId",
          "equals": true
        },
        {
          "kind": "resultField",
          "field": "$.sameLeaseToken",
          "equals": true
        },
        {
          "kind": "resultField",
          "field": "$.sameIdempotencyKey",
          "equals": true
        },
        {
          "kind": "resultField",
          "field": "$.idempotencyKeyPresent",
          "equals": true
        },
        {
          "kind": "resultField",
          "field": "$.redeliveredInvocationCount",
          "equals": 1
        },
        {
          "kind": "resultField",
          "field": "$.sessionRejectionRedeliveredCount",
          "equals": 0
        },
        {
          "kind": "resultField",
          "field": "$.finalStatus",
          "equals": "completed"
        }
      ],
      "evidence": [
        "sameCallId",
        "sameLeaseToken",
        "sameIdempotencyKey",
        "idempotencyKeyPresent",
        "redeliveredInvocationCount",
        "sessionRejectionRedeliveredCount",
        "finalStatus"
      ]
    },
    {
      "checkId": "host-session.grace-window-expiry-settles-binding-unavailable",
      "operation": "host-session.grace-window-expiry",
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.persistedToolResultOutputCode",
          "equals": "capability_binding_unavailable"
        },
        {
          "kind": "resultField",
          "field": "$.sessionEnded",
          "equals": true
        },
        {
          "kind": "resultField",
          "field": "$.finalStatus",
          "equals": "completed"
        }
      ],
      "evidence": [
        "persistedToolResultOutputCode",
        "sessionEnded",
        "pendingTimersBeforeDetach",
        "pendingTimersAfterDetach",
        "finalStatus"
      ]
    },
    {
      "checkId": "host-session.dispatch-timeout-settles-while-attached",
      "operation": "host-session.dispatch-timeout",
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.persistedToolResultOutputCode",
          "equals": "capability_dispatch_timeout"
        },
        {
          "kind": "resultField",
          "field": "$.pendingTimersWhileAttached",
          "equals": 1
        },
        {
          "kind": "resultField",
          "field": "$.pendingTimersAfterDetach",
          "equals": 1
        },
        {
          "kind": "resultField",
          "field": "$.pendingTimersAfterReattach",
          "equals": 1
        },
        {
          "kind": "resultField",
          "field": "$.redeliveredInvocationCount",
          "equals": 1
        },
        {
          "kind": "resultField",
          "field": "$.finalStatus",
          "equals": "completed"
        }
      ],
      "evidence": [
        "persistedToolResultOutputCode",
        "pendingTimersWhileAttached",
        "pendingTimersAfterDetach",
        "pendingTimersAfterReattach",
        "redeliveredInvocationCount",
        "finalStatus"
      ]
    },
    {
      "checkId": "host-session.sequence-continuity-across-reattach",
      "operation": "host-session.sequence-continuity",
      "assertions": [
        {
          "kind": "resultField",
          "field": "$.resumeStatus",
          "equals": "resumed"
        },
        {
          "kind": "resultField",
          "field": "$.noSequenceRestart",
          "equals": true
        },
        {
          "kind": "resultField",
          "field": "$.replayGaplessAndContiguous",
          "equals": true
        }
      ],
      "evidence": [
        "resumeStatus",
        "noSequenceRestart",
        "replayGaplessAndContiguous",
        "replayedSequences",
        "expectedReplaySequences"
      ]
    }
  ]
}
