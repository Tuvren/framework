{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuvren.dev/schemas/framework/runner-api/RunnerExecutionResult.json",
  "type": "object",
  "properties": {
    "resolution": {
      "$ref": "https://tuvren.dev/schemas/framework/runner-api/RunnerRuntimeResolution.json"
    },
    "messages": {
      "type": "array",
      "items": {
        "$ref": "https://tuvren.dev/schemas/framework/runner-api/TuvrenMessage.json"
      }
    },
    "partial": {
      "type": "boolean"
    },
    "toolExecutionMode": {
      "anyOf": [
        {
          "type": "string",
          "const": "parallel"
        },
        {
          "type": "string",
          "const": "sequential"
        }
      ]
    },
    "assistantEventReconciliation": {
      "type": "string",
      "const": "allow_final_sequence_divergence"
    },
    "stateUpdates": {
      "type": "array",
      "items": {
        "$ref": "https://tuvren.dev/schemas/framework/runner-api/RunnerExtensionStateUpdate.json"
      }
    }
  },
  "required": ["resolution"],
  "unevaluatedProperties": {
    "not": {}
  }
}
