{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "composite": false,
    "rootDir": "../../",
    "allowImportingTsExtensions": true,
    "paths": {
      "@tuvren/core": ["../core/src/index.ts"],
      "@tuvren/core/errors": ["../core/src/errors/index.ts"],
      "@tuvren/core/tools": ["../core/src/tools/index.ts"],
      "@tuvren/core/lifecycle": ["../core/src/lifecycle/index.ts"],
      "@tuvren/core/telemetry": ["../core/src/telemetry/index.ts"],
      "@tuvren/core/capabilities": ["../core/src/capabilities/index.ts"],
      "@tuvren/core/events": ["../core/src/events/index.ts"],
      "@tuvren/core/execution": ["../core/src/execution/index.ts"],
      "@tuvren/core/extensions": ["../core/src/extensions/index.ts"],
      "@tuvren/core/messages": ["../core/src/messages/index.ts"],
      "@tuvren/core/provider": ["../core/src/provider/index.ts"],
      "@tuvren/core/runner": ["../core/src/runner/index.ts"],
      "@tuvren/core/security": ["../core/src/security/index.ts"],
      "@tuvren/kernel-protocol": ["../kernel/protocol/src/index.ts"],
      "@tuvren/kernel-runtime": ["../kernel/runtime/src/index.ts"],
      "@tuvren/backend-memory": ["../kernel/backends/memory/src/index.ts"],
      "@tuvren/backend-shared": ["../kernel/backends/shared/src/index.ts"],
      "@tuvren/backend-sqlite": ["../kernel/backends/sqlite/src/index.ts"],
      "@tuvren/backend-postgres": ["../kernel/backends/postgres/src/index.ts"],
      "@tuvren/kernel-testkit": ["../kernel/testkit/src/index.ts"],
      "@tuvren/framework-testkit": ["../testkit/src/index.ts"],
      "@tuvren/runtime": ["../runtime/src/index.ts"],
      "@tuvren/provider-api": ["../providers/provider-api/src/index.ts"],
      "@tuvren/mcp-client": ["../tools/mcp-client/src/index.ts"],
      "@tuvren/stream-core": ["../streaming/core/src/index.ts"],
      "@tuvren/stream-sse": ["../streaming/sse/src/index.ts"],
      "@tuvren/stream-agui": ["../streaming/agui/src/index.ts"],
      "@tuvren/telemetry-otel": ["../telemetry/otel/src/index.ts"],
      "@tuvren/telemetry-semconv": ["../telemetry/semconv/src/index.ts"],
      "@tuvren/sdk": ["./src/index.ts"]
    },
    "types": ["bun", "node"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "../core/src/**/*.ts"]
}
