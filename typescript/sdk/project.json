{
  "name": "sdk",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "typescript/sdk",
  "sourceRoot": "typescript/sdk/src",
  "projectType": "library",
  "tags": ["boundary:shared", "layer:implementation"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "typescript/sdk",
        "command": "bunx --bun tsup --config tsup.config.ts && bunx --bun tsc --project tsconfig.dts.json --pretty false"
      },
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bunx --bun @biomejs/biome check typescript/sdk"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "typescript/sdk",
        "command": "bun test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bun tools/scripts/typecheck-project.ts typescript/sdk"
      }
    },
    "api-freeze-check": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bun tools/scripts/api-freeze-gate.ts --check"
      },
      "cache": true,
      "inputs": [
        "{workspaceRoot}/typescript/**/package.json",
        "!{workspaceRoot}/typescript/**/node_modules/**",
        "!{workspaceRoot}/typescript/**/dist/**",
        "{workspaceRoot}/typescript/**/src/**/*",
        "{workspaceRoot}/tools/scripts/api-freeze-gate.ts",
        "{workspaceRoot}/tools/scripts/lib/api-freeze-model.ts",
        "{workspaceRoot}/tools/scripts/lib/walk-package-manifests.ts",
        "{workspaceRoot}/tools/scripts/__snapshots__/api-surface/**/*",
        "{workspaceRoot}/spec/core/authority-packet.json"
      ]
    }
  }
}
