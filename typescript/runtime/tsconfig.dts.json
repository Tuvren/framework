{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "paths": {
      "@tuvren/core-types": ["../core-types/dist/index.d.ts"],
      "@tuvren/core": ["../core/dist/index.d.ts"],
      "@tuvren/core/errors": ["../core/dist/errors/index.d.ts"],
      "@tuvren/core/messages": ["../core/dist/messages/index.d.ts"],
      "@tuvren/core/events": ["../core/dist/events/index.d.ts"],
      "@tuvren/core/execution": ["../core/dist/execution/index.d.ts"],
      "@tuvren/core/tools": ["../core/dist/tools/index.d.ts"],
      "@tuvren/core/driver": ["../core/dist/driver/index.d.ts"],
      "@tuvren/core/provider": ["../core/dist/provider/index.d.ts"],
      "@tuvren/core/extensions": ["../core/dist/extensions/index.d.ts"],
      "@tuvren/core/telemetry": ["../core/dist/telemetry/index.d.ts"],
      "@tuvren/sdk": ["../sdk/dist/index.d.ts"],
      "@tuvren/driver-react": [
        "../../boundaries/framework/implementations/typescript/drivers/react/dist/index.d.ts"
      ],
      "@tuvren/kernel-protocol": ["../kernel/protocol/dist/index.d.ts"],
      "@tuvren/kernel-runtime": ["../kernel/runtime/dist/index.d.ts"],
      "@tuvren/runtime-api": [
        "../../boundaries/framework/contracts/runtime-api/implementations/typescript/dist/index.d.ts"
      ]
    },
    "rootDir": "./src",
    "target": "esnext",
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts"]
}
