{
  "name": "backend-sqlite",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "root": "typescript/kernel/backends/sqlite",
  "sourceRoot": "typescript/kernel/backends/sqlite/src",
  "projectType": "library",
  "tags": ["boundary:kernel", "layer:implementation"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "typescript/kernel/backends/sqlite",
        "command": "bunx --bun tsup --config tsup.config.ts && bun ../../../../tools/scripts/compile-with-migrations.ts --tsconfig tsconfig.dts.json --out dist"
      }
    },
    "bench": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "typescript/kernel/backends/sqlite",
        "command": "bun ../../../../tools/scripts/compile-with-migrations.ts --clean .tmp-bench --tsconfig tsconfig.bench.json --out .tmp-bench/typescript/kernel/backends/sqlite && node .tmp-bench/typescript/kernel/backends/sqlite/bench/sqlite-hot-path.bench.js"
      }
    },
    "bench-load-cost": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "typescript/kernel/backends/sqlite",
        "command": "bun ../../../../tools/scripts/compile-with-migrations.ts --clean .tmp-bench --tsconfig tsconfig.bench.json --out .tmp-bench/typescript/kernel/backends/sqlite && node .tmp-bench/typescript/kernel/backends/sqlite/bench/sqlite-load-cost.bench.js"
      }
    },
    "retention-dry-run": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "typescript/kernel/backends/sqlite",
        "command": "bun ../../../../tools/scripts/compile-with-migrations.ts --clean .tmp-bench --tsconfig tsconfig.bench.json --out .tmp-bench/typescript/kernel/backends/sqlite && node .tmp-bench/typescript/kernel/backends/sqlite/bench/sqlite-retention-dry-run.js"
      }
    },
    "smoke-native": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "typescript/kernel/backends/sqlite",
        "command": "node -e \"const Database=require('better-sqlite3'); const db=new Database(':memory:'); console.log(db.prepare('SELECT 1 AS value').get().value); db.close();\""
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bunx --bun @biomejs/biome check typescript/kernel/backends/sqlite"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build", "smoke-native"],
      "options": {
        "cwd": "typescript/kernel/backends/sqlite",
        "command": "bun ../../../../tools/scripts/compile-with-migrations.ts --clean .tmp-tests --tsconfig tsconfig.test.json --out .tmp-tests/typescript/kernel/backends/sqlite && node --experimental-test-module-mocks --test .tmp-tests/typescript/kernel/backends/sqlite/test/*.test.js"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bun tools/scripts/typecheck-project.ts typescript/kernel/backends/sqlite"
      }
    }
  }
}
