{
  "name": "framework-typescript-conformance-adapter",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "typescript/conformance-adapter",
  "projectType": "library",
  "tags": [
    "boundary:framework",
    "language:typescript",
    "layer:conformance-adapter"
  ],
  "targets": {
    "build-batteries-included": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "inputs": [
        "{projectRoot}/src/**",
        "{projectRoot}/tsup.config.batteries-included.ts",
        {
          "externalDependencies": ["tsup"]
        }
      ],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "typescript/conformance-adapter",
        "command": "bunx --bun tsup --config tsup.config.batteries-included.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bunx --bun @biomejs/biome check typescript/conformance-adapter"
      }
    }
  }
}
