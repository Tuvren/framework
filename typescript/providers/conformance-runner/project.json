{
  "name": "providers-typescript-conformance-runner",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "root": "typescript/providers/conformance-runner",
  "projectType": "library",
  "tags": [
    "boundary:providers",
    "language:typescript",
    "layer:conformance-runner"
  ],
  "targets": {
    "conformance": {
      "executor": "nx:run-commands",
      "inputs": [
        "default",
        "^production",
        "conformanceEngine",
        "{workspaceRoot}/spec/conformance/providers/**/*",
        "{workspaceRoot}/typescript/providers/conformance-adapter/**/*"
      ],
      "options": {
        "cwd": ".",
        "command": "bun tools/conformance/runner/run.ts --adapter typescript/providers/conformance-adapter/adapter.json --summary-only"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bunx --bun @biomejs/biome check typescript/providers/conformance-runner"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "typescript/providers/conformance-runner",
        "command": "bun test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bun tools/scripts/typecheck-project.ts typescript/providers/conformance-runner"
      }
    }
  }
}
