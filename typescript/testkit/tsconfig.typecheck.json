{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "composite": false,
    "rootDir": "../..",
    "allowImportingTsExtensions": true,
    "paths": {
      "@tuvren/core": ["../core/src/index.ts"],
      "@tuvren/core/driver": ["../core/src/driver/index.ts"],
      "@tuvren/core/errors": ["../core/src/errors/index.ts"],
      "@tuvren/core/events": ["../core/src/events/index.ts"],
      "@tuvren/core/execution": ["../core/src/execution/index.ts"],
      "@tuvren/core/extensions": ["../core/src/extensions/index.ts"],
      "@tuvren/core/telemetry": ["../core/src/telemetry/index.ts"],
      "@tuvren/core/messages": ["../core/src/messages/index.ts"],
      "@tuvren/core/provider": ["../core/src/provider/index.ts"],
      "@tuvren/core/tools": ["../core/src/tools/index.ts"],
      "@tuvren/event-stream": [
        "../../boundaries/framework/contracts/event-stream/implementations/typescript/src/index.ts"
      ]
    },
    "types": ["bun", "node"]
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "../../boundaries/framework/contracts/event-stream/implementations/typescript/src/**/*.ts"
  ]
}
