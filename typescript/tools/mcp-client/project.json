{
  "name": "mcp-client",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "root": "typescript/tools/mcp-client",
  "sourceRoot": "typescript/tools/mcp-client/src",
  "projectType": "library",
  "tags": ["boundary:providers", "layer:implementation"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "cwd": "typescript/tools/mcp-client",
        "command": "bunx --bun tsup --config tsup.config.ts && bunx --bun tsc --project tsconfig.dts.json --pretty false"
      }
    },
    "exports-smoke": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "typescript/tools/mcp-client",
        "command": "bun test ./smoke/package-exports.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bunx --bun @biomejs/biome check typescript/tools/mcp-client"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "typescript/tools/mcp-client",
        "command": "bun test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "bun tools/scripts/typecheck-project.ts typescript/tools/mcp-client"
      }
    }
  }
}
