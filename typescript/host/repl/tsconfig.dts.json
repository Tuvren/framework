{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "paths": {
      "@tuvren/backend-memory": [
        "../../../typescript/kernel/backends/memory/dist/index.d.ts"
      ],
      "@tuvren/backend-sqlite": [
        "../../../typescript/kernel/backends/sqlite/dist/index.d.ts"
      ],
      "@tuvren/provider-bridge-ai-sdk": [
        "../../../typescript/providers/bridge-ai-sdk/dist/index.d.ts"
      ],
      "@tuvren/runtime": ["../../../typescript/runtime/dist/index.d.ts"],
      "@tuvren/stream-agui": [
        "../../../typescript/streaming/agui/dist/index.d.ts"
      ],
      "@tuvren/stream-core": [
        "../../../typescript/streaming/core/dist/index.d.ts"
      ],
      "@tuvren/stream-sse": [
        "../../../typescript/streaming/sse/dist/index.d.ts"
      ]
    },
    "rootDir": "./src",
    "target": "esnext",
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts"]
}
