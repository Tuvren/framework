{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "paths": {
      "@tuvren/backend-memory": [
        "../../../typescript/kernel/backends/memory/dist/index.d.ts"
      ],
      "@tuvren/backend-sqlite": [
        "../../../typescript/kernel/backends/sqlite/dist/index.d.ts"
      ],
      "@tuvren/provider-bridge-ai-sdk": [
        "../../../typescript/providers/bridge-ai-sdk/dist/index.d.ts"
      ],
      "@tuvren/sdk": ["../../../typescript/sdk/dist/index.d.ts"],
      "@tuvren/sdk/advanced": ["../../../typescript/sdk/dist/advanced.d.ts"],
      "@tuvren/kernel-grpc-client": [
        "../../../typescript/kernel/grpc-client/dist/index.d.ts"
      ],
      "@tuvren/telemetry-semconv": [
        "../../../typescript/telemetry/semconv/dist/index.d.ts"
      ],
      "@tuvren/stream-agui": [
        "../../../typescript/streaming/agui/dist/index.d.ts"
      ],
      "@tuvren/stream-core": [
        "../../../typescript/streaming/core/dist/index.d.ts"
      ],
      "@tuvren/stream-sse": [
        "../../../typescript/streaming/sse/dist/index.d.ts"
      ],
      "@tuvren/core": ["../../../typescript/core/dist/index.d.ts"],
      "@tuvren/core/capabilities": [
        "../../../typescript/core/dist/capabilities/index.d.ts"
      ],
      "@tuvren/host-session": [
        "../../../typescript/host/session/dist/index.d.ts"
      ],
      "@tuvren/remote-session": [
        "../../../typescript/host/remote-session/dist/index.d.ts"
      ],
      "@tuvren/stream-ws": ["../../../typescript/streaming/ws/dist/index.d.ts"],
      "@tuvren/session-client": [
        "../../../typescript/host/session-client/dist/index.d.ts"
      ]
    },
    "rootDir": "./src",
    // P2-7: bun-types and the DOM lib both declare overlapping globals (e.g.
    // WebSocket, fetch) with incompatible shapes; without skipLibCheck the
    // declaration build fails on that clash rather than on anything this
    // package's own source does wrong.
    "skipLibCheck": true,
    "target": "esnext",
    "types": ["bun", "node"],
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts"]
}
