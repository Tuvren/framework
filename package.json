{
  "name": "tuvren-runtime",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "better-sqlite3"
  ],
  "workspaces": [
    "typescript/*",
    "typescript/host/*",
    "typescript/kernel/*",
    "typescript/kernel/backends/*",
    "typescript/providers/*",
    "typescript/runners/*",
    "typescript/streaming/*",
    "typescript/telemetry/*",
    "typescript/tools/*"
  ],
  "scripts": {
    "lint": "bunx --bun @biomejs/biome check . && bun tools/scripts/kraken-surface-gate.ts",
    "format": "bunx --bun @biomejs/biome check --write .",
    "nx": "bun ./tools/run-nx.mjs",
    "typecheck": "bun run nx run-many -t typecheck --parallel=4",
    "conformance": "bun tools/scripts/conformance.ts",
    "compatibility:evidence": "bun run nx run compatibility-reporting:evidence-refresh --skipNxCache",
    "compatibility:check": "bun run nx run compatibility-reporting:check",
    "codegen": "bun tools/scripts/codegen.ts",
    "interop-smoke": "bun run nx run-many -t interop-smoke -p kernel-interop-grpc,kernel-rust-grpc-service,host-repl --parallel=1",
    "proving-host:interop-smoke": "bun run nx run host-repl:interop-smoke --skipNxCache --excludeTaskDependencies",
    "proving-host:scenario-sqlite": "bun run nx run host-repl:scenario-sqlite",
    "proving-host:scenario-postgres": "bun run nx run host-repl:scenario-postgres",
    "docs:authority-freeze": "bun tools/scripts/docs-authority-freeze-gate.ts",
    "docs:authority-freeze:check": "bun tools/scripts/docs-authority-freeze-gate.ts --check",
    "docs:af-gap-plan": "bun tools/scripts/epic-af-conformance-gap-plan.ts",
    "docs:af-gap-plan:check": "bun tools/scripts/epic-af-conformance-gap-plan.ts --check",
    "portability:check": "bun tools/scripts/portability-gate.ts",
    "host-boundary:check": "bun tools/scripts/host-boundary-gate.ts",
    "api-freeze": "bun tools/scripts/api-freeze-gate.ts --update",
    "api-freeze:check": "bun tools/scripts/api-freeze-gate.ts --check",
    "services:up": "bash tools/scripts/services-up.sh",
    "services:down": "devenv processes down",
    "check": "bun tools/scripts/check.ts",
    "verify:kernel": "bun tools/scripts/verify-kernel.ts",
    "verify:kernel:fresh": "bun tools/scripts/verify-kernel.ts --fresh",
    "verify": "bun tools/scripts/verify.ts",
    "release-check": "bun tools/scripts/release-check.ts",
    "release": "bun tools/scripts/release-lane.ts",
    "publish:preflight": "bun tools/scripts/publish-registry.ts --preflight",
    "publish:dry-run": "bun tools/scripts/publish-registry.ts --dry-run",
    "publish:registry": "bun tools/scripts/publish-registry.ts --publish",
    "graph": "bun run nx graph"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@changesets/cli": "^2.31.0",
    "@nx/js": "22.6.3",
    "@nx/workspace": "22.6.3",
    "@standard-schema/spec": "1.1.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@typespec/compiler": "1.11.0",
    "@typespec/events": "0.81.0",
    "@typespec/http": "1.11.0",
    "@typespec/json-schema": "1.11.0",
    "@typespec/openapi": "1.11.0",
    "@typespec/openapi3": "1.11.0",
    "@typespec/rest": "0.81.0",
    "@typespec/sse": "0.81.0",
    "@typespec/streams": "0.81.0",
    "@typespec/versioning": "0.81.0",
    "ajv": "8.18.0",
    "better-sqlite3": "12.8.0",
    "cbor-x": "1.6.4",
    "cddl": "0.20.1",
    "nx": "22.6.3",
    "tsup": "8.5.1",
    "typescript": "6.0.2",
    "ultracite": "7.4.2",
    "yaml": "^2.9.0",
    "zod": "4.4.3"
  }
}
