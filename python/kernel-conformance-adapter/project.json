{
  "name": "kernel-python-conformance-adapter",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "python/kernel-conformance-adapter",
  "projectType": "library",
  "tags": ["boundary:kernel", "language:python", "layer:conformance-adapter"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "cwd": ".",
        "command": "uv run --project python/kernel-conformance-adapter python -c \"import tuvren_kernel_adapter\""
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "uv run --project python/kernel-conformance-adapter ruff check python/kernel-conformance-adapter/src python/kernel-conformance-adapter/tests && uv run --project python/kernel-conformance-adapter ruff format --check python/kernel-conformance-adapter/src python/kernel-conformance-adapter/tests"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "uv run --project python/kernel-conformance-adapter pytest python/kernel-conformance-adapter/tests"
      }
    }
  }
}
