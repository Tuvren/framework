{
  "name": "kernel-python-kernel",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "python/kernel",
  "projectType": "library",
  "tags": ["boundary:kernel", "language:python", "layer:implementation"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [],
      "inputs": [
        "default",
        "{workspaceRoot}/pyproject.toml",
        "{workspaceRoot}/uv.lock"
      ],
      "options": {
        "cwd": ".",
        "command": "uv run --project python/kernel python -c \"import tuvren_kernel\""
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "inputs": [
        "default",
        "{workspaceRoot}/pyproject.toml",
        "{workspaceRoot}/uv.lock"
      ],
      "options": {
        "cwd": ".",
        "command": "uv run --project python/kernel ruff check python/kernel/src python/kernel/tests && uv run --project python/kernel ruff format --check python/kernel/src python/kernel/tests"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "inputs": [
        "default",
        "{workspaceRoot}/pyproject.toml",
        "{workspaceRoot}/uv.lock"
      ],
      "options": {
        "cwd": ".",
        "command": "uv run --project python/kernel pytest python/kernel/tests"
      }
    }
  }
}
