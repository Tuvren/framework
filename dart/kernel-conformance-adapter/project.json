{
  "name": "kernel-dart-conformance-adapter",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "dart/kernel-conformance-adapter",
  "projectType": "library",
  "tags": ["boundary:kernel", "language:dart", "layer:conformance-adapter"],
  "implicitDependencies": ["kernel-dart-kernel"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [],
      "inputs": [
        "default",
        "{workspaceRoot}/dart/kernel/**/*",
        "{workspaceRoot}/pubspec.yaml",
        "{workspaceRoot}/pubspec.lock"
      ],
      "options": {
        "cwd": "dart/kernel-conformance-adapter",
        "command": "dart analyze"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "inputs": [
        "default",
        "{workspaceRoot}/pubspec.yaml",
        "{workspaceRoot}/pubspec.lock"
      ],
      "options": {
        "cwd": "dart/kernel-conformance-adapter",
        "command": "dart format --output=none --set-exit-if-changed . && dart analyze --fatal-infos"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "inputs": [
        "default",
        "{workspaceRoot}/dart/kernel/**/*",
        "{workspaceRoot}/pubspec.yaml",
        "{workspaceRoot}/pubspec.lock"
      ],
      "options": {
        "cwd": "dart/kernel-conformance-adapter",
        "command": "dart test"
      }
    }
  }
}
