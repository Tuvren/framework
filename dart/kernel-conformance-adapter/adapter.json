{
  "adapterId": "dart-kernel",
  "implementationId": "dart-kernel",
  "language": "dart",
  "boundary": "kernel",
  "protocol": {
    "name": "tuvren.conformance-adapter",
    "version": "0.1.0",
    "transport": "json-rpc-2.0-stdio"
  },
  "command": ["dart", "run", "dart/kernel-conformance-adapter/bin/main.dart"],
  "capabilities": [
    "kernel.protocol",
