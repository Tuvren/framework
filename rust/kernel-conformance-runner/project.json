{
  "name": "kernel-rust-conformance-runner",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "rust/kernel-conformance-runner",
  "projectType": "library",
  "tags": ["boundary:kernel", "language:rust", "layer:conformance-runner"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "cwd": ".",
        "command": "cargo build -p tuvren-kernel-rust-conformance-runner -p tuvren-kernel-rust-conformance-adapter"
      }
    },
    "conformance": {
      "executor": "nx:run-commands",
      "inputs": [
        "default",
        "^production",
        "conformanceEngine",
        "{workspaceRoot}/spec/conformance/kernel/**/*",
        "{workspaceRoot}/rust/kernel/**/*",
        "{workspaceRoot}/rust/kernel-conformance-adapter/**/*",
        "{workspaceRoot}/rust/kernel-conformance-runner/**/*",
        "{workspaceRoot}/Cargo.toml",
        "{workspaceRoot}/Cargo.lock",
        "{workspaceRoot}/rust-toolchain.toml"
      ],
      "options": {
        "cwd": ".",
        "command": "bun tools/conformance/runner/run.ts --adapter rust/kernel-conformance-adapter/adapter.json --summary-only"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "cargo fmt --package tuvren-kernel-rust-conformance-runner -- --check && cargo fmt --package tuvren-kernel-rust-conformance-adapter -- --check && cargo clippy -p tuvren-kernel-rust-conformance-runner --all-targets -- -D warnings && cargo clippy -p tuvren-kernel-rust-conformance-adapter --all-targets -- -D warnings"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "cargo test -p tuvren-kernel-rust-conformance-runner -p tuvren-kernel-rust-conformance-adapter"
      }
    }
  }
}
