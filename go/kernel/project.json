{
  "name": "kernel-go-kernel",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "go/kernel",
  "projectType": "library",
  "tags": ["boundary:kernel", "language:go", "layer:implementation"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "cwd": "go/kernel",
        "command": "go build ./..."
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "go/kernel",
        "command": "test -z \"$(gofmt -l .)\" && go vet ./..."
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "go/kernel",
        "command": "go test ./..."
      }
    }
  }
}
